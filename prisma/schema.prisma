generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  users       User[]
  rolePermissions RolePermission[]
  @@map("roles")
}

model Permission {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  rolePermissions RolePermission[]
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  phone           String?    @unique
  password        String
  roleId          String     @map("role_id")
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  lastLoginAt     DateTime?  @map("last_login_at")
  image           String?
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  role             Role              @relation(fields: [roleId], references: [id])
  customer         Customer?
  createdVisits    Visit[]           @relation("VisitCreator")
  createdBillings  Billing[]         @relation("BillingCreator")
  receivedPayments Payment[]         @relation("PaymentReceiver")
  stockAdjustments StockAdjustment[] @relation("StockAdjustmentCreator")
  posOrders        PosOrder[]        @relation("PosCreator")
  auditLogs        AuditLog[]
  notifications    Notification[]
  @@index([roleId])
  @@index([status])
  @@map("users")
}

model Customer {
  id        String        @id @default(cuid())
  name      String
  phone     String        @unique
  email     String?
  address   String?
  city      String?
  postalCode String?      @map("postal_code")
  userId    String?       @unique @map("user_id")
  status    CustomerStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  pets          Pet[]
  visits        Visit[]
  billings      Billing[]
  invoices      Invoice[]
  posOrders     PosOrder[]
  prescriptions Prescription[]
  @@index([status])
  @@index([name])
  @@map("customers")
}

model Pet {
  id                  String    @id @default(cuid())
  customerId          String    @map("customer_id")
  name                String
  species             String
  breed               String?
  birthDate           DateTime? @map("birth_date")
  weightKg            Decimal?  @map("weight_kg") @db.Decimal(5, 2)
  colorMarking        String?   @map("color_marking")
  medicalHistoryNotes String?   @map("medical_history_notes")
  image               String?
  status              PetStatus @default(ACTIVE)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  visits        Visit[]
  billings      Billing[]
  invoices      Invoice[]
  prescriptions Prescription[]
  @@index([customerId])
  @@index([species])
  @@index([status])
  @@map("pets")
}

enum ServiceCategory {
  KONSULTASI
  VAKSINASI
  GROOMING
  OPERASI
  LABORATORIUM
  XRAY
  RAWAT_INAP
  LAINNYA
}

model Service {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  category    ServiceCategory
  price       Decimal         @db.Decimal(12, 2)
  status      MasterStatus    @default(ACTIVE)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  visitItems   VisitItem[]
  billingItems BillingItem[]
  @@index([category])
  @@index([status])
  @@index([name])
  @@map("services")
}

enum DrugUnit {
  TABLET
  KAPSULA
  BOTOL
  VIAL
  AMPUL
  GRAM
  ML
  TETES
  LAINNYA
}

model Drug {
  id              String       @id @default(cuid())
  name            String       @unique
  description     String?
  unit            DrugUnit
  pricePerUnit    Decimal      @map("price_per_unit") @db.Decimal(12, 2)
  status          MasterStatus @default(ACTIVE)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  visitItems         VisitItem[]
  billingItems       BillingItem[]
  prescriptionItems  PrescriptionItem[]
  @@index([status])
  @@index([name])
  @@map("drugs")
}

model ProductCategory {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  status      MasterStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  products Product[]
  @@index([status])
  @@map("product_categories")
}

model Product {
  id            String          @id @default(cuid())
  name          String          @unique
  categoryId    String          @map("category_id")
  price         Decimal         @db.Decimal(12, 2)
  description   String?
  image         String?
  barcode       String?
  currentStock  Int             @default(0) @map("current_stock")
  reorderPoint  Int             @default(10) @map("reorder_point")
  status        MasterStatus    @default(ACTIVE)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  category         ProductCategory   @relation(fields: [categoryId], references: [id])
  posOrderItems    PosOrderItem[]
  billingItems     BillingItem[]
  stockAdjustments StockAdjustment[]
  @@index([categoryId])
  @@index([barcode])
  @@index([status])
  @@index([name])
  @@map("products")
}

enum VisitStatus {
  DRAFT
  COMPLETED
  PAID
}

model Visit {
  id                String      @id @default(cuid())
  visitNumber       String      @unique @map("visit_number")
  customerId        String      @map("customer_id")
  petId             String      @map("pet_id")
  visitDate         DateTime    @map("visit_date")
  chiefComplaint    String      @map("chief_complaint")
  physicalExamNotes String?     @map("physical_exam_notes")
  diagnosis         String
  treatmentNotes    String?     @map("treatment_notes")
  weightKg          Decimal?    @map("weight_kg") @db.Decimal(5, 2)
  temperature       Decimal?    @db.Decimal(4, 1)
  heartRate         Int?        @map("heart_rate")
  status            VisitStatus @default(DRAFT)
  createdBy         String      @map("created_by")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  customer   Customer   @relation(fields: [customerId], references: [id])
  pet        Pet        @relation(fields: [petId], references: [id])
  creator    User       @relation("VisitCreator", fields: [createdBy], references: [id])
  visitItems VisitItem[]
  prescription Prescription?

  @@index([customerId])
  @@index([petId])
  @@index([visitDate])
  @@index([status])
  @@index([createdBy])
  @@map("visits")
}

model VisitItem {
  id        String     @id @default(cuid())
  visitId   String     @map("visit_id")
  itemType  Itemtype   @map("item_type")
  serviceId String?    @map("service_id")
  drugId    String?    @map("drug_id")
  quantity  Int        @default(1)
  unitPrice Decimal    @map("unit_price") @db.Decimal(12, 2)
  subtotal  Decimal    @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime   @default(now()) @map("created_at")
  visit   Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])
  drug    Drug?    @relation(fields: [drugId], references: [id])
  @@index([visitId])
  @@index([itemType])
  @@map("visit_items")
}

enum BillingStatus {
  OPEN
  COMPLETED
  PAID
  SETTLED
}

model Billing {
  id              String        @id @default(cuid())
  billingNumber   String        @unique @map("billing_number")
  customerId      String        @map("customer_id")
  petId           String        @map("pet_id")
  billingStartDate DateTime    @map("billing_start_date")
  billingEndDate  DateTime?     @map("billing_end_date")
  status          BillingStatus @default(OPEN)
  notes           String?
  createdBy       String        @map("created_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  customer     Customer     @relation(fields: [customerId], references: [id])
  pet          Pet          @relation(fields: [petId], references: [id])
  creator      User         @relation("BillingCreator", fields: [createdBy], references: [id])
  billingItems BillingItem[]
  @@index([customerId])
  @@index([petId])
  @@index([status])
  @@index([createdBy])
  @@map("billings")
}

model BillingItem {
  id        String     @id @default(cuid())
  billingId String     @map("billing_id")
  itemType  Itemtype   @map("item_type")
  serviceId String?    @map("service_id")
  drugId    String?    @map("drug_id")
  productId String?    @map("product_id")
  quantity  Int        @default(1)
  unitPrice Decimal    @map("unit_price") @db.Decimal(12, 2)
  subtotal  Decimal    @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime   @default(now()) @map("created_at")
  billing Billing  @relation(fields: [billingId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])
  drug    Drug?    @relation(fields: [drugId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
  @@index([billingId])
  @@index([itemType])
  @@map("billing_items")
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
}

enum SourceType {
  VISIT
  BILLING
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique @map("invoice_number")
  customerId     String        @map("customer_id")
  petId          String?       @map("pet_id")
  sourceType     SourceType    @map("source_type")
  sourceId       String        @map("source_id")
  invoiceDate    DateTime      @map("invoice_date")
  dueDate        DateTime?     @map("due_date")
  subtotal       Decimal       @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  status         InvoiceStatus @default(UNPAID)
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  customer     Customer     @relation(fields: [customerId], references: [id])
  pet          Pet?         @relation(fields: [petId], references: [id])
  invoiceItems InvoiceItem[]
  @@index([customerId])
  @@index([status])
  @@index([invoiceDate])
  @@index([sourceType, sourceId])
  @@map("invoices")
}

model InvoiceItem {
  id        String   @id @default(cuid())
  invoiceId String   @map("invoice_id")
  itemName  String   @map("item_name")
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(12, 2)
  subtotal  Decimal  @db.Decimal(12, 2)
  category  String?
  createdAt DateTime @default(now()) @map("created_at")
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  @@index([invoiceId])
  @@map("invoice_items")
}

enum PrescriptionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Prescription {
  id                 String             @id @default(cuid())
  prescriptionNumber String             @unique @map("prescription_number")
  visitId            String             @map("visit_id")
  customerId         String             @map("customer_id")
  petId              String             @map("pet_id")
  prescriptionDate   DateTime           @map("prescription_date")
  status             PrescriptionStatus @default(ACTIVE)
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  pet               Pet               @relation(fields: [petId], references: [id])
  customer          Customer          @relation(fields: [customerId], references: [id])
  visit             Visit             @relation(fields: [visitId], references: [id])
  prescriptionItems PrescriptionItem[]
  @@unique([visitId])
  @@index([visitId])
  @@index([customerId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String   @id @default(cuid())
  prescriptionId String   @map("prescription_id")
  drugId         String   @map("drug_id")
  quantity       Int
  dosage         String?
  durationDays   Int?     @map("duration_days")
  instructions   String?
  createdAt      DateTime @default(now()) @map("created_at")
  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  drug         Drug         @relation(fields: [drugId], references: [id])
  @@index([prescriptionId])
  @@map("prescription_items")
}

model PosOrder {
  id             String   @id @default(cuid())
  orderNumber    String   @unique @map("order_number")
  customerId     String?  @map("customer_id")
  subtotal       Decimal  @db.Decimal(12, 2)
  taxAmount      Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discountAmount Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  total          Decimal  @db.Decimal(12, 2)
  paymentMethod  String   @map("payment_method")
  paymentAmount  Decimal  @map("payment_amount") @db.Decimal(12, 2)
  changeAmount   Decimal  @default(0) @map("change_amount") @db.Decimal(12, 2)
  status         String   @default("COMPLETED")
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  creator      User          @relation("PosCreator", fields: [createdBy], references: [id])
  posOrderItems PosOrderItem[]
  @@index([customerId])
  @@index([createdAt])
  @@index([status])
  @@map("pos_orders")
}

model PosOrderItem {
  id         String   @id @default(cuid())
  posOrderId String   @map("pos_order_id")
  productId  String   @map("product_id")
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(12, 2)
  subtotal   Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  posOrder PosOrder @relation(fields: [posOrderId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
  @@index([posOrderId])
  @@map("pos_order_items")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model Payment {
  id            String        @id @default(cuid())
  paymentNumber String        @unique @map("payment_number")
  payableType   String        @map("payable_type")
  payableId     String        @map("payable_id")
  paymentMethod String        @map("payment_method")
  amount        Decimal       @db.Decimal(12, 2)
  status        PaymentStatus @default(PAID)
  notes         String?
  receivedBy    String        @map("received_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  receiver User @relation("PaymentReceiver", fields: [receivedBy], references: [id])
  @@index([payableType, payableId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

enum StockReason {
  INITIAL
  POS_SOLD
  DAMAGED
  RETURN
  OPNAME_ADJUST
  OTHER
}

model StockAdjustment {
  id          String      @id @default(cuid())
  productId   String      @map("product_id")
  quantity    Int
  reason      StockReason
  referenceId String?     @map("reference_id")
  createdBy   String      @map("created_by")
  notes       String?
  createdAt   DateTime    @default(now()) @map("created_at")
  product Product @relation(fields: [productId], references: [id])
  creator User    @relation("StockAdjustmentCreator", fields: [createdBy], references: [id])
  @@index([productId])
  @@index([createdAt])
  @@map("stock_adjustments")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ARCHIVE
  PAYMENT
  STATUS_CHANGE
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?     @map("user_id")
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  changes    Json?
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")
  user User? @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  title     String
  message   String
  type      String
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("settings")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum PetStatus {
  ACTIVE
  ARCHIVED
}

enum MasterStatus {
  ACTIVE
  ARCHIVED
}

enum Itemtype {
  SERVICE
  DRUG
  PRODUCT
}
